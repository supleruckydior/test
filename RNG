-- 安全获取对象函数
local function safeGet(path)
    local current = game
    for _, part in ipairs(path) do
        local success, child = pcall(function() return current[part] end)
        if not success or not child then
            return nil
        end
        current = child
    end
    return current
end

-- 优化后的WaitClearFrame检测（持续3秒可见才触发）
local function getWaitClearVisible()
    local totalVisibleTime = 0
    local checkInterval = 0.3
    local requiredDuration = 0.8
    
    while running do
        local waitFrame = safeGet({
            "Players", player.Name, 
            "PlayerGui", "MainGui", 
            "ScreenGui", "ArenaStatusView", 
            "ResultFrame"
        })
        
        if waitFrame and waitFrame:IsA("Frame") and waitFrame.Visible then
            totalVisibleTime = totalVisibleTime + checkInterval
            if totalVisibleTime >= requiredDuration then
                return true
            end
        else
            totalVisibleTime = 0
        end
        
        wait(checkInterval)
    end
    return false
end

-- 安全检测ArenaStatusView是否存在
local function isInBattle()
    local arenaView = safeGet({
        "Players", player.Name,
        "PlayerGui", "MainGui",
        "ScreenGui", "ArenaStatusView"
    })
    return arenaView and arenaView:IsA("Frame")
end

-- 浮空控制函数
local function floatAbovePosition()
    -- 清理现有状态
    if currentFloatTask then
        currentFloatTask:Disconnect()
        currentFloatTask = nil
    end

    local Character = player.Character or player.CharacterAdded:Wait()
    local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
    local Humanoid = Character:WaitForChild("Humanoid")

    -- 清理旧控制器
    for _, child in ipairs(HumanoidRootPart:GetChildren()) do
        if child:IsA("BodyPosition") or child:IsA("BodyForce") then
            child:Destroy()
        end
    end

    -- 创建新控制器
    local bodyPos = Instance.new("BodyPosition")
    bodyPos.Position = HumanoidRootPart.Position + Vector3.new(0, 25, 0)
    bodyPos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyPos.D = 1000
    bodyPos.P = 10000
    bodyPos.Parent = HumanoidRootPart

    local bodyForce = Instance.new("BodyForce")
    bodyForce.Force = Vector3.new(0, HumanoidRootPart:GetMass() * workspace.Gravity, 0)
    bodyForce.Parent = HumanoidRootPart

    Humanoid:ChangeState(Enum.HumanoidStateType.Physics)

    -- 战斗结束检测
    currentFloatTask = game:GetService("RunService").Heartbeat:Connect(function()
        if not running then
            if currentFloatTask then
                currentFloatTask:Disconnect()
                currentFloatTask = nil
            end
            return
        end

        if getWaitClearVisible() then
            print("检测到WaitClearFrame持续3秒，取消浮空")
            if currentFloatTask then
                currentFloatTask:Disconnect()
                currentFloatTask = nil
            end
            
            pcall(function()
                bodyPos:Destroy()
                bodyForce:Destroy()
                Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            end)
        end
    end)
end

-- Boss区域检测
local function checkBossArea(areaId)
    local guiAth = safeGet({
        "Workspace", "AreaModel", "101", 
        "Area", "CommonGui", 
        "ArenaSoloShower_"..areaId, "GuiAth"
    })
    
    if not guiAth then
        warn("["..areaId.."] 路径获取失败")
        return false
    end

    local function searchLabCd(instance)
        if instance:IsA("TextLabel") and instance.Name == "LabCdTime" then
            local text = instance.Text
            return text == "LabCdTime" or text == "CD: 00:00:00"
        end
        for _, child in ipairs(instance:GetChildren()) do
            if searchLabCd(child) then return true end
        end
        return false
    end

    return searchLabCd(guiAth)
end

-- 灵兽系统（改进版）
local function checkLingShouSystem()
    -- 安全检测WaitClearFrame
    local waitFrame = safeGet({
        "Players", player.Name, 
        "PlayerGui", "MainGui", 
        "ScreenGui", "ArenaStatusView", 
        "WaitClearFrame"
    })
    
    if not waitFrame or not waitFrame:IsA("Frame") or not waitFrame.Visible then
        return false
    end

    print("检测到灵兽触发条件")
    
    -- 获取所有怪物
    local monsters = workspace.Monsters:GetChildren()
    if #monsters == 0 then
        warn("没有找到怪物")
        return false
    end
    
    -- 收集所有有效的怪物ID
    local monsterIds = {}
    for _, monster in ipairs(monsters) do
        local monsterName = monster.Name
        local number = string.match(monsterName, "%d+")
        
        if number then
            number = tonumber(number)
            table.insert(monsterIds, number)
            print("找到怪物ID:", number)
        else
            warn("无法从怪物名称中提取数字:", monsterName)
        end
    end
    
    if #monsterIds == 0 then
        warn("没有有效的怪物ID")
        return false
    end
  
    
    -- 对每个怪物ID执行三次灵兽调用
    for _, monsterId in ipairs(monsterIds) do
        for i = 1, 3 do
            local args = {
                "LingShouSystemRollChannel",
                monsterId,
                1
            }
            
            print(string.format("正在对怪物ID %d 执行第%d次灵兽调用...", monsterId, i))
            local success, err = pcall(function()
                game:GetService("ReplicatedStorage").CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc:InvokeServer(unpack(args))
            end)
            
            if success then
                print(string.format("怪物ID %d 第%d次灵兽调用成功", monsterId, i))
            else
                warn(string.format("怪物ID %d 第%d次灵兽调用失败:", monsterId, i), err)
            end
            
            if i < 3 then
            wait(1)
            end
        end
    end
    
    return true
end

-- ========== 主循环 ==========
local function main()
    while running and gui.Parent do
        -- Boss区域检测
        for areaId, enabled in pairs(areaConfig) do
            if enabled and not isInBattle() then
                local success, ready = pcall(checkBossArea, areaId)
                if success and ready then
                    print("["..areaId.."] 可进入战斗")
                    
                    local args = {"ArenaStartSoloArenaChannel", areaId}
                    local invokeSuccess, err = pcall(function()
                        game:GetService("ReplicatedStorage").CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc:InvokeServer(unpack(args))
                    end)
                    
                    if invokeSuccess then
                        print("战斗请求已发送")
                        hasEnteredBattle = true
                        
                        local startTime = os.time()
                        local hasTriggered = false
                        
                        while running and (os.time() - startTime < 15) do
                            if isInBattle() and not hasTriggered then
                                print("进入战斗，启动浮空")
                                floatAbovePosition()
                                hasTriggered = true
                                break
                            end
                            task.wait(0.3)
                        end
                    else
                        warn("战斗请求失败:", err)
                    end
                end
            end
        end

        -- 战斗结束后传送到目标位置
        if hasEnteredBattle and not isInBattle() then
            local character = player.Character
            if character then
                local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                if humanoidRootPart then
                    print("战斗结束，传送到目标位置")
                    wait(2)
                    humanoidRootPart.CFrame = CFrame.new(targetPosition)
                    hasEnteredBattle = false
                end
            end
        end

        -- 灵兽系统检测
        if lingShouStatus then
            pcall(checkLingShouSystem)
        end

        task.wait(1)
    end
end

