-- 安全获取对象函数
local function safeGet(path)
    local current = game
    for _, part in ipairs(path) do
        local success, child = pcall(function() return current[part] end)
        if not success or not child then
            return nil
        end
        current = child
    end
    return current
end

-- 检查GuiAth下所有LabCdTime
local function checkAnyLabCdTime(areaId)
    local guiAthPath = {"Workspace", "AreaModel", "101", "Area", "CommonGui", "ArenaSoloShower_"..areaId, "GuiAth"}
    local guiAth = safeGet(guiAthPath)
    
    if not guiAth then
        warn("["..areaId.."] GuiAth路径获取失败")
        return false
    end
    
    -- 递归搜索所有LabCdTime
    local function searchLabCdTime(instance)
        if instance:IsA("TextLabel") and instance.Name == "LabCdTime" then
            local text = instance.Text
            if text == "LabCdTime" or text == "CD: 00:00:00" then
                return true
            end
        end
        
        for _, child in ipairs(instance:GetChildren()) do
            if searchLabCdTime(child) then
                return true
            end
        end
        
        return false
    end
    
    return searchLabCdTime(guiAth)
end

-- 灵兽系统检查函数
local function checkLingShouSystem()
    -- 检查WaitClearFrame是否可见
    local framePath = {"Players", player.Name, "PlayerGui", "MainGui", "ScreenGui", "ArenaStatusView", "WaitClearFrame"}
    local waitFrame = safeGet(framePath)
    
    if not waitFrame or not waitFrame:IsA("Frame") then
        warn("灵兽框架获取失败")
        return false
    end
    
    if waitFrame.Visible then
        print("检测到灵兽触发条件")
        
        -- 获取第一个怪物
        local monsters = workspace.Monsters:GetChildren()
        if #monsters == 0 then
            warn("没有找到怪物")
            return false
        end
        
        local monster = monsters[1]
        local monsterName = monster.Name
        local number = string.match(monsterName, "%d+")
        
        if not number then
            warn("无法从怪物名称中提取数字:", monsterName)
            return false
        end
        
        number = tonumber(number)
        print("找到怪物ID:", number)
        
        -- 执行三次调用
        for i = 1, 3 do
            local args = {
                "LingShouSystemRollChannel",
                number,
                1
            }
            
            print("正在执行第"..i.."次灵兽调用...")
            local success, err = pcall(function()
                game:GetService("ReplicatedStorage").CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc:InvokeServer(unpack(args))
            end)
            
            if success then
                print("第"..i.."次灵兽调用成功")
            else
                warn("第"..i.."次灵兽调用失败:", err)
            end
            
            if i < 3 then
                wait(1)
            end
        end
        return true
    end
    return false
end

-- 主循环
local function main()
    while running and gui.Parent do
        -- 检查Boss区域
        for areaId, enabled in pairs(areaConfig) do
            if enabled then
                local success, result = pcall(checkAnyLabCdTime, areaId)
                if success and result then
                    print("["..areaId.."] 检测到可战斗Boss")
                    
                    local args = {"ArenaStartSoloArenaChannel", areaId}
                    local invokeSuccess, err = pcall(function()
                        game:GetService("ReplicatedStorage").CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc:InvokeServer(unpack(args))
                    end)
                    
                    if not invokeSuccess then
                        warn("["..areaId.."] Boss执行失败:", err)
                    end
                elseif not success then
                    warn("["..areaId.."] Boss检查出错:", result)
                end
            end
        end
        
        -- 检查灵兽系统
        if lingShouStatus then
            local success, err = pcall(checkLingShouSystem)
            if not success then
                warn("灵兽系统检查出错:", err)
            end
        end
        
        wait(1)
    end
    
    if gui and gui.Parent then 
        gui:Destroy()
    end
end

-- 启动脚本
local success, err = pcall(main)
if not success then
    warn("主循环错误:", err)
    if gui and gui.Parent then
        gui:Destroy()
    end
end
